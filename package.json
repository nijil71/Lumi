{
  "name": "@nijil71/lumi-cli",
  "version": "1.0.9",
  "description": "Terminal UI components — spinners, progress bars, boxes, tables, banners — zero dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/types.d.ts",
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "lumi": "./src/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "demo.js"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=esm --outfile=dist/index.js --platform=node --minify --legal-comments=none",
    "demo": "node src/cli.js demo",
    "smoke": "node --test test/smoke.test.js",
    "units": "node --test test/units.test.js",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nijil71/Lumi.git"
  },
  "homepage": "https://github.com/nijil71/Lumi#readme",
  "bugs": {
    "url": "https://github.com/nijil71/Lumi/issues"
  },
  "keywords": [
    "cli",
    "terminal",
    "spinner",
    "progress",
    "progress-bar",
    "box",
    "table",
    "banner",
    "ascii-art",
    "logger",
    "tui",
    "ansi",
    "zero-dependency"
  ],
  "author": "Nijil N M <nmnijilkhan@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
